---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import RelatedTools from '../components/RelatedTools.astro';
import FAQ from '../components/FAQ.astro';
import type { Tool } from '../types/tool';

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  tool: Tool;
  title: string;
  description: string;
  faqs?: FAQItem[];
  relatedTools?: Tool[];
  schema?: object;
}

const { tool, title, description, faqs = [], relatedTools = [], schema } = Astro.props;

const breadcrumbs = [
  { label: tool.category, href: `/${tool.categorySlug}` },
  { label: tool.name },
];

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `${tool.name} | ToolHub`,
  "description": description,
  "url": `https://toolhub.dev/${tool.categorySlug}/${tool.slug}`,
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolhub.dev" },
      { "@type": "ListItem", "position": 2, "name": tool.category, "item": `https://toolhub.dev/${tool.categorySlug}` },
      { "@type": "ListItem", "position": 3, "name": tool.name },
    ],
  },
};
---

<BaseLayout
  title={`${tool.name} | ToolHub`}
  description={description}
  schema={schema ?? toolSchema}
>
  <Header currentPath={`/${tool.categorySlug}`} />

  <main id="main-content" class="mx-auto max-w-[1400px] px-4 md:px-6 py-8">
    <!-- Breadcrumb -->
    <div class="mb-6">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <!-- Tool Header -->
    <header class="mb-8">
      <h1 class="text-display-lg mb-2" style="color: var(--color-ink);">{tool.name}</h1>
      <p class="text-body-lg max-w-2xl" style="color: var(--color-body-text);">{description}</p>
      <p class="mt-2 text-caption-mono" style="color: var(--color-mute);">
        All processing happens locally in your browser.
      </p>
    </header>

    <!-- Tool Interface -->
    <div class="mb-12">
      <slot name="tool" />
    </div>

    <!-- Supporting Content -->
    <div class="max-w-3xl">
      <slot name="content" />
    </div>

    <!-- FAQs -->
    {faqs.length > 0 && (
      <div class="max-w-3xl">
        <FAQ items={faqs} />
      </div>
    )}

    <!-- Related Tools -->
    {relatedTools.length > 0 && (
      <RelatedTools tools={relatedTools} />
    )}
  </main>

  <Footer />
</BaseLayout>

<style>
  html.dark h1 {
    color: var(--color-dark-ink) !important;
  }
  html.dark p {
    color: var(--color-dark-body) !important;
  }
</style>
