---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug, getRelatedTools } from '../../data/tools';

const tool = getToolBySlug('generators', 'password-generator')!;
const relatedTools = getRelatedTools(tool, 4);

const faqs = [
  { question: 'Is this password generator secure?', answer: 'Yes. Passwords are generated using the Web Crypto API (crypto.getRandomValues), which provides cryptographically secure random values. Your password is never sent to any server.' },
  { question: 'What makes a strong password?', answer: 'A strong password is at least 16 characters long and includes uppercase letters, lowercase letters, numbers, and symbols. Avoid using dictionary words or personal information.' },
  { question: 'Should I use a password manager?', answer: 'Yes. We recommend storing generated passwords in a reputable password manager rather than writing them down or reusing them.' },
  { question: 'What are similar characters?', answer: 'Similar characters are visually ambiguous characters like 0 (zero) and O (letter O), or 1 (one) and l (lowercase L). Excluding them makes passwords easier to read.' },
];
---

<ToolLayout
  tool={tool}
  title="Password Generator"
  description="Generate strong, secure passwords with custom length and character options. Uses the Web Crypto API for cryptographically secure randomness. Free, no signup."
  faqs={faqs}
  relatedTools={relatedTools}
>
  <div slot="tool" class="space-y-6 max-w-xl">
    <!-- Generated Password -->
    <div>
      <label class="block text-sm font-medium mb-2" style="color: var(--color-ink);">Generated password</label>
      <div class="flex items-center gap-2">
        <div
          class="flex-1 rounded-lg border px-4 py-3 font-mono text-sm break-all min-h-[48px] flex items-center"
          style="background-color: var(--color-canvas-soft-2); border-color: var(--color-hairline); color: var(--color-ink);"
          id="password-display"
          aria-live="polite"
          aria-label="Generated password"
        >
          Click Generate to create a password
        </div>
        <button
          id="btn-copy-password"
          type="button"
          class="shrink-0 inline-flex items-center gap-1.5 rounded-lg border px-3 h-12 text-sm font-medium transition-colors hover:border-[var(--color-hairline-strong)]"
          style="border-color: var(--color-hairline); color: var(--color-body-text); background-color: var(--color-canvas);"
          aria-label="Copy password"
        >
          Copy
        </button>
      </div>
      <!-- Strength indicator -->
      <div class="mt-2 flex items-center gap-2">
        <div class="flex gap-1" id="strength-bars" aria-label="Password strength">
          {[1,2,3,4].map(i => (
            <div class="h-1.5 w-8 rounded-full" style="background-color: var(--color-hairline);" data-bar={i}></div>
          ))}
        </div>
        <span id="strength-label" class="text-caption" style="color: var(--color-mute);">—</span>
      </div>
    </div>

    <!-- Length -->
    <div>
      <div class="flex items-center justify-between mb-2">
        <label for="length-slider" class="text-sm font-medium" style="color: var(--color-ink);">Length</label>
        <span id="length-display" class="text-sm font-mono font-medium" style="color: var(--color-ink);">16</span>
      </div>
      <input
        id="length-slider"
        type="range"
        min="4"
        max="128"
        value="16"
        class="w-full accent-[var(--color-ink)] cursor-pointer"
        aria-label="Password length"
      />
      <div class="flex justify-between text-caption mt-1" style="color: var(--color-mute);">
        <span>4</span><span>128</span>
      </div>
    </div>

    <!-- Options -->
    <fieldset>
      <legend class="text-sm font-medium mb-3" style="color: var(--color-ink);">Character types</legend>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        {[
          { id: 'opt-upper', label: 'Uppercase (A–Z)', checked: true },
          { id: 'opt-lower', label: 'Lowercase (a–z)', checked: true },
          { id: 'opt-numbers', label: 'Numbers (0–9)', checked: true },
          { id: 'opt-symbols', label: 'Symbols (!@#$...)', checked: true },
          { id: 'opt-no-similar', label: 'Exclude similar (0, O, l, 1)', checked: false },
          { id: 'opt-no-ambiguous', label: 'Exclude ambiguous ({[]})', checked: false },
        ].map((opt) => (
          <label class="flex items-center gap-2 text-sm cursor-pointer rounded-md border px-3 py-2 transition-colors hover:border-[var(--color-hairline-strong)]" style="border-color: var(--color-hairline); color: var(--color-body-text);">
            <input type="checkbox" id={opt.id} checked={opt.checked} class="accent-[var(--color-ink)]" />
            {opt.label}
          </label>
        ))}
      </div>
    </fieldset>

    <!-- Generate Button -->
    <button
      id="btn-generate"
      type="button"
      class="w-full rounded-full h-11 font-medium text-sm transition-opacity hover:opacity-90"
      style="background-color: var(--color-ink); color: #ffffff;"
    >
      Generate Password
    </button>

    <!-- Bulk Generate -->
    <details class="rounded-lg border" style="border-color: var(--color-hairline);">
      <summary class="px-4 py-3 text-sm font-medium cursor-pointer list-none" style="color: var(--color-ink);">
        Generate multiple passwords
      </summary>
      <div class="px-4 pb-4 space-y-3">
        <div class="flex items-center gap-3">
          <label for="bulk-count" class="text-sm shrink-0" style="color: var(--color-body-text);">Count:</label>
          <input id="bulk-count" type="number" min="1" max="50" value="5" class="rounded-md border px-3 h-8 text-sm w-20" style="background-color: var(--color-canvas); border-color: var(--color-hairline); color: var(--color-ink);" />
          <button id="btn-bulk" type="button" class="rounded-full border px-4 h-8 text-sm font-medium" style="border-color: var(--color-hairline); color: var(--color-body-text); background-color: var(--color-canvas);">Generate</button>
        </div>
        <textarea id="bulk-output" rows="6" readonly class="w-full rounded-lg border px-3 py-2 text-sm font-mono" style="background-color: var(--color-canvas-soft-2); border-color: var(--color-hairline); color: var(--color-ink);" aria-live="polite"></textarea>
      </div>
    </details>
  </div>

  <div slot="content">
    <section aria-labelledby="how-to-use">
      <h2 id="how-to-use" class="text-display-sm mb-3" style="color: var(--color-ink);">How to use</h2>
      <ol class="space-y-2 text-sm leading-relaxed" style="color: var(--color-body-text);">
        <li>1. Set your desired password length using the slider.</li>
        <li>2. Choose which character types to include.</li>
        <li>3. Click <strong>Generate Password</strong> to create a new password.</li>
        <li>4. Click <strong>Copy</strong> to copy it to your clipboard.</li>
      </ol>
    </section>
  </div>
</ToolLayout>

<script>
  const display = document.getElementById('password-display')!;
  const btnCopy = document.getElementById('btn-copy-password')!;
  const btnGenerate = document.getElementById('btn-generate')!;
  const lengthSlider = document.getElementById('length-slider') as HTMLInputElement;
  const lengthDisplay = document.getElementById('length-display')!;
  const strengthBars = document.querySelectorAll('[data-bar]');
  const strengthLabel = document.getElementById('strength-label')!;
  const btnBulk = document.getElementById('btn-bulk')!;
  const bulkOutput = document.getElementById('bulk-output') as HTMLTextAreaElement;
  const bulkCount = document.getElementById('bulk-count') as HTMLInputElement;

  const UPPER = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  const LOWER = 'abcdefghijklmnopqrstuvwxyz';
  const NUMBERS = '0123456789';
  const SYMBOLS = '!@#$%^&*()_+-=[]{}|;:,.<>?';
  const SIMILAR = /[0Ol1I]/g;
  const AMBIGUOUS = /[{}[\]()\/\\'"~,;.<>]/g;

  function getOpt(id: string): boolean {
    return (document.getElementById(id) as HTMLInputElement)?.checked ?? false;
  }

  function secureRandom(max: number): number {
    const arr = new Uint32Array(1);
    crypto.getRandomValues(arr);
    return arr[0] % max;
  }

  function generatePassword(length: number): string {
    let charset = '';
    if (getOpt('opt-upper')) charset += UPPER;
    if (getOpt('opt-lower')) charset += LOWER;
    if (getOpt('opt-numbers')) charset += NUMBERS;
    if (getOpt('opt-symbols')) charset += SYMBOLS;
    if (!charset) charset = LOWER + NUMBERS;

    if (getOpt('opt-no-similar')) charset = charset.replace(SIMILAR, '');
    if (getOpt('opt-no-ambiguous')) charset = charset.replace(AMBIGUOUS, '');
    if (!charset) charset = LOWER;

    let password = '';
    for (let i = 0; i < length; i++) {
      password += charset[secureRandom(charset.length)];
    }
    return password;
  }

  function getStrength(password: string): { score: number; label: string; color: string } {
    let score = 0;
    if (password.length >= 8) score++;
    if (password.length >= 16) score++;
    if (/[A-Z]/.test(password) && /[a-z]/.test(password)) score++;
    if (/[0-9]/.test(password)) score++;
    if (/[^A-Za-z0-9]/.test(password)) score++;
    if (score <= 1) return { score: 1, label: 'Weak', color: '#ee0000' };
    if (score === 2) return { score: 2, label: 'Fair', color: '#f5a623' };
    if (score === 3) return { score: 3, label: 'Good', color: '#0070f3' };
    return { score: 4, label: 'Strong', color: '#10b981' };
  }

  function updateStrength(password: string) {
    const { score, label, color } = getStrength(password);
    strengthBars.forEach((bar, i) => {
      (bar as HTMLElement).style.backgroundColor = i < score ? color : 'var(--color-hairline)';
    });
    strengthLabel.textContent = label;
    strengthLabel.style.color = color;
  }

  function generate() {
    const length = parseInt(lengthSlider.value, 10);
    const password = generatePassword(length);
    display.textContent = password;
    updateStrength(password);
  }

  lengthSlider.addEventListener('input', () => {
    lengthDisplay.textContent = lengthSlider.value;
  });

  btnGenerate.addEventListener('click', generate);

  btnCopy.addEventListener('click', async () => {
    const text = display.textContent ?? '';
    if (!text || text.includes('Click Generate')) return;
    await navigator.clipboard.writeText(text).catch(() => {});
    const orig = btnCopy.textContent;
    btnCopy.textContent = 'Copied!';
    setTimeout(() => { btnCopy.textContent = orig; }, 2000);
  });

  btnBulk.addEventListener('click', () => {
    const count = Math.min(50, Math.max(1, parseInt(bulkCount.value, 10) || 5));
    const length = parseInt(lengthSlider.value, 10);
    const passwords = Array.from({ length: count }, () => generatePassword(length));
    bulkOutput.value = passwords.join('\n');
  });

  // Generate on load
  generate();
</script>

<style>
  html.dark #password-display { background-color: var(--color-dark-canvas-soft-2) !important; border-color: var(--color-dark-hairline) !important; color: var(--color-dark-ink) !important; }
  html.dark button[style*="var(--color-canvas)"] { background-color: var(--color-dark-canvas-soft) !important; border-color: var(--color-dark-hairline) !important; color: var(--color-dark-body) !important; }
  html.dark label[style*="var(--color-body-text)"] { color: var(--color-dark-body) !important; border-color: var(--color-dark-hairline) !important; }
  html.dark details { border-color: var(--color-dark-hairline) !important; }
  html.dark summary { color: var(--color-dark-ink) !important; }
  html.dark textarea { background-color: var(--color-dark-canvas-soft-2) !important; border-color: var(--color-dark-hairline) !important; color: var(--color-dark-ink) !important; }
  html.dark input[type="number"] { background-color: var(--color-dark-canvas-soft) !important; border-color: var(--color-dark-hairline) !important; color: var(--color-dark-ink) !important; }
</style>
