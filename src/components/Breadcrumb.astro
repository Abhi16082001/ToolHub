---
import { getIcon } from '../utils/icons';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.label,
    ...(item.href ? { "item": `https://toolhub.dev${item.href}` } : {}),
  })),
};
---

<nav aria-label="Breadcrumb" class="breadcrumb flex items-center gap-1.5 text-sm flex-wrap">
  <a
    href="/"
    class="breadcrumb-link flex items-center gap-1 rounded-full px-1.5 py-1 transition-colors duration-150 hover:bg-[var(--color-primary-soft)] hover:text-[var(--color-primary)]"
    style="color: var(--color-mute);"
    aria-label="Home"
  >
    <span set:html={getIcon('home', 13)} />
  </a>

  {items.map((item, i) => (
    <>
      <span class="breadcrumb-separator" style="color: var(--color-hairline-strong);" aria-hidden="true">
        <span set:html={getIcon('chevron-right', 12)} />
      </span>
      {item.href && i < items.length - 1 ? (
        <a
          href={item.href}
          class="breadcrumb-link rounded-full px-1.5 py-1 transition-colors duration-150 hover:bg-[var(--color-primary-soft)] hover:text-[var(--color-primary)]"
          style="color: var(--color-mute);"
        >
          {item.label}
        </a>
      ) : (
        <span class="breadcrumb-current rounded-full px-1.5 py-1" style="color: var(--color-body-text);" aria-current="page">
          {item.label}
        </span>
      )}
    </>
  ))}
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<style>
  html.dark .breadcrumb-link {
    color: var(--color-dark-mute) !important;
  }
  html.dark .breadcrumb-link:hover {
    color: var(--color-dark-primary) !important;
    background-color: var(--color-dark-primary-soft) !important;
  }
  html.dark .breadcrumb-separator {
    color: var(--color-dark-hairline-strong) !important;
  }
  html.dark .breadcrumb-current {
    color: var(--color-dark-body) !important;
    background-color: color-mix(in srgb, var(--color-dark-canvas-soft-2) 72%, transparent) !important;
  }
</style>
