---
import { getIcon } from '../utils/icons';

interface Props {
  currentPath?: string;
}
const { currentPath = '' } = Astro.props;

const navLinks = [
  { label: 'Text Tools', href: '/text-tools' },
  { label: 'Developer', href: '/developer-tools' },
  { label: 'Converters', href: '/converter-tools' },
  { label: 'Calculators', href: '/calculators' },
  { label: 'Generators', href: '/generators' },
];
---

<header
  class="sticky top-0 z-50 w-full border-b backdrop-blur-md transition-colors duration-200"
  style="background-color: color-mix(in srgb, var(--color-canvas) 92%, transparent); border-color: var(--color-hairline);"
  id="site-header"
>
  <div class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-4 md:px-6">
    <a
      href="/"
      class="site-logo flex items-center gap-2 font-semibold text-base tracking-tight transition-opacity duration-150 hover:opacity-90"
      style="color: var(--color-ink);"
      aria-label="ToolHub Home"
    >
      <span
        class="flex h-8 w-8 items-center justify-center rounded-lg text-white text-sm font-semibold shadow-card"
        style="background: linear-gradient(135deg, var(--color-primary), var(--color-teal));"
        aria-hidden="true"
      >T</span>
      <span>ToolHub</span>
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      {navLinks.map((link) => {
        const isActive = currentPath.startsWith(link.href);
        return (
          <a
            href={link.href}
            class="nav-link rounded-full px-3 py-1.5 text-sm transition-colors duration-150 hover:bg-[var(--color-primary-soft)] hover:text-[var(--color-primary)]"
            style={isActive
              ? 'color: var(--color-primary); background-color: var(--color-primary-soft); font-weight: 500; box-shadow: inset 0 0 0 1px var(--color-primary-soft-strong);'
              : 'color: var(--color-body-text);'}
            aria-current={isActive ? 'page' : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="/search"
        class="search-link hidden sm:flex items-center gap-2 rounded-full border px-3 h-9 text-sm transition-colors duration-150 hover:border-[var(--color-primary)] hover:text-[var(--color-primary)]"
        style="color: var(--color-mute); border-color: var(--color-hairline); background-color: var(--color-canvas);"
        aria-label="Search tools"
      >
        <span set:html={getIcon('search', 14)} />
        <span class="hidden lg:inline">Search tools&hellip;</span>
        <kbd class="hidden lg:inline text-xs rounded-full px-1.5 py-0.5" style="background-color: var(--color-primary-soft); color: var(--color-primary);">Ctrl K</kbd>
      </a>

      <button
        data-theme-toggle
        class="icon-action flex h-9 w-9 items-center justify-center rounded-full border transition-colors duration-150 hover:border-[var(--color-primary)] hover:text-[var(--color-primary)]"
        style="border-color: var(--color-hairline); color: var(--color-body-text); background-color: var(--color-canvas);"
        aria-label="Toggle dark mode"
        type="button"
      >
        <span data-theme-icon-sun set:html={getIcon('sun', 15)} />
        <span data-theme-icon-moon style="display:none;" set:html={getIcon('moon', 15)} />
      </button>

      <button
        id="mobile-menu-btn"
        class="icon-action flex md:hidden h-9 w-9 items-center justify-center rounded-full border transition-colors duration-150 hover:border-[var(--color-primary)] hover:text-[var(--color-primary)]"
        style="border-color: var(--color-hairline); color: var(--color-body-text); background-color: var(--color-canvas);"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <span id="menu-icon-open" set:html={getIcon('menu', 16)} />
        <span id="menu-icon-close" class="hidden" set:html={getIcon('x', 16)} />
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden md:hidden border-t shadow-card"
    style="border-color: var(--color-hairline); background-color: var(--color-canvas);"
    aria-hidden="true"
  >
    <nav class="mx-auto max-w-[1400px] px-4 py-3 flex flex-col gap-1" aria-label="Mobile navigation">
      {navLinks.map((link) => {
        const isActive = currentPath.startsWith(link.href);
        return (
          <a
            href={link.href}
            class="mobile-nav-link rounded-lg px-3 py-2 text-sm transition-colors duration-150 hover:bg-[var(--color-primary-soft)] hover:text-[var(--color-primary)]"
            style={isActive
              ? 'color: var(--color-primary); background-color: var(--color-primary-soft); font-weight: 500;'
              : 'color: var(--color-body-text);'}
            aria-current={isActive ? 'page' : undefined}
          >
            {link.label}
          </a>
        );
      })}
      <a
        href="/search"
        class="mobile-nav-link rounded-lg px-3 py-2 text-sm transition-colors duration-150 hover:bg-[var(--color-primary-soft)] hover:text-[var(--color-primary)]"
        style="color: var(--color-body-text);"
      >
        Search Tools
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    menu?.setAttribute('aria-hidden', String(!isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });

  const isDark = document.documentElement.classList.contains('dark');
  const sunIcons = document.querySelectorAll('[data-theme-icon-sun]');
  const moonIcons = document.querySelectorAll('[data-theme-icon-moon]');
  sunIcons.forEach(el => (el as HTMLElement).style.display = isDark ? 'none' : 'block');
  moonIcons.forEach(el => (el as HTMLElement).style.display = isDark ? 'block' : 'none');
</script>

<style>
  html.dark header {
    background-color: color-mix(in srgb, var(--color-dark-canvas) 92%, transparent) !important;
    border-color: var(--color-dark-hairline) !important;
  }
  html.dark #mobile-menu {
    background-color: var(--color-dark-canvas-soft) !important;
    border-color: var(--color-dark-hairline) !important;
  }
  html.dark .site-logo {
    color: var(--color-dark-ink) !important;
  }
  html.dark .nav-link,
  html.dark .mobile-nav-link {
    color: var(--color-dark-body) !important;
  }
  html.dark .nav-link:hover,
  html.dark .mobile-nav-link:hover {
    color: var(--color-dark-primary) !important;
    background-color: var(--color-dark-primary-soft) !important;
  }
  html.dark .nav-link[aria-current="page"],
  html.dark .mobile-nav-link[aria-current="page"] {
    color: var(--color-dark-primary) !important;
    background-color: var(--color-dark-primary-soft) !important;
    box-shadow: inset 0 0 0 1px var(--color-dark-hairline-strong) !important;
  }
  html.dark .search-link,
  html.dark .icon-action {
    background-color: var(--color-dark-canvas-soft) !important;
    border-color: var(--color-dark-hairline) !important;
    color: var(--color-dark-body) !important;
  }
  html.dark .search-link:hover,
  html.dark .icon-action:hover {
    border-color: var(--color-dark-primary) !important;
    color: var(--color-dark-primary) !important;
  }
  html.dark kbd {
    background-color: var(--color-dark-primary-soft) !important;
    color: var(--color-dark-primary) !important;
  }
</style>
