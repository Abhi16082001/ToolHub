---
import { getIcon } from '../utils/icons';
import type { Tool } from '../types/tool';

interface Props {
  tool: Tool;
  size?: 'sm' | 'md';
}

const { tool, size = 'md' } = Astro.props;
const href = `/${tool.categorySlug}/${tool.slug}`;
---

<a
  href={href}
  class={`group flex items-start gap-3 rounded-lg border transition-all duration-150 hover:-translate-y-0.5 shadow-card hover:shadow-card-md ${size === 'sm' ? 'p-3' : 'p-4'}`}
  style="background-color: var(--color-canvas); border-color: var(--color-hairline); text-decoration: none;"
>
  <!-- Icon -->
  <span
    class={`flex shrink-0 items-center justify-center rounded-md ${size === 'sm' ? 'h-8 w-8' : 'h-9 w-9'}`}
    style="background-color: var(--color-canvas-soft-2); color: var(--color-body-text);"
    aria-hidden="true"
  >
    <span set:html={getIcon(tool.icon, size === 'sm' ? 16 : 18)} />
  </span>

  <!-- Content -->
  <div class="min-w-0 flex-1">
    <p
      class={`font-medium leading-snug truncate transition-colors group-hover:text-[var(--color-link)] ${size === 'sm' ? 'text-sm' : 'text-sm'}`}
      style="color: var(--color-ink);"
    >
      {tool.name}
    </p>
    {size === 'md' && (
      <p class="mt-0.5 text-xs leading-relaxed line-clamp-2" style="color: var(--color-mute);">
        {tool.description}
      </p>
    )}
  </div>

  <!-- Arrow -->
  <span
    class="shrink-0 opacity-0 group-hover:opacity-100 transition-opacity mt-0.5"
    style="color: var(--color-mute);"
    aria-hidden="true"
  >
    <span set:html={getIcon('chevron-right', 14)} />
  </span>
</a>

<style>
  html.dark a[href] {
    background-color: var(--color-dark-canvas-soft) !important;
    border-color: var(--color-dark-hairline) !important;
  }
  html.dark a[href] p:first-child {
    color: var(--color-dark-ink) !important;
  }
  html.dark a[href] p:last-child {
    color: var(--color-dark-mute) !important;
  }
  html.dark a[href] span:first-child {
    background-color: var(--color-dark-canvas-soft-2) !important;
    color: var(--color-dark-body) !important;
  }
</style>
